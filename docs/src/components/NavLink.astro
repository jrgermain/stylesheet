---
interface Props {
  class: string;
  href: string;
}

const { class: className, href } = Astro.props;

const path = new URL(Astro.request.url).pathname;
const isActive = path === href || path.startsWith(`${href}/`);
---

<a class={className} href={href} aria-current={isActive ? "page" : undefined}
  ><slot /></a
>
