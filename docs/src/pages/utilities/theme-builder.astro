---
import PageTitle from "../../components/PageTitle.astro";
import Section from "../../components/theme-builder/Section.astro";
import Layout from "../../layouts/Layout.astro";
import Field from "../../components/Field.astro";
import RadioCard from "../../components/theme-builder/RadioCard.astro";
import GraySwatch from "../../components/theme-builder/GraySwatch.astro";
import RoundnessArc from "../../components/theme-builder/RoundnessArc.astro";
import DensityIcon from "../../components/theme-builder/DensityIcon.astro";
---

<Layout title="Theme Builder">
  <div class="toolbar">
    <label for="color-mode" class="side-label">Color Mode</label>
    <div class="field compact">
      <select id="color-mode" class="input">
        <option value="auto">Auto</option>
        <option value="light">Light</option>
        <option value="dark">Dark</option>
      </select>
    </div>
    <hr class="divider vertical" />
    <button id="reset" class="button small red">Reset</button>
    <button
      class="button small primary"
      command="show-modal"
      commandfor="examples-drawer"
    >
      Show Examples
    </button>
  </div>

  <dialog
    id="examples-drawer"
    class="drawer bottom"
    aria-labelledby="examples-drawer-title"
  >
    <header class="drawer-header">
      <h1 id="examples-drawer-title">Examples</h1>
      <button
        class="button dismiss"
        command="request-close"
        commandfor="examples-drawer"
        aria-label="Close"></button>
    </header>
    <div class="drawer-body">
      <div class="card">
        <div class="card secondary">
          <h2 class="heading level-4" style="margin-block-start:0">Prose</h2>
          <p class="paragraph">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
            eiusmod tempor incididunt ut labore et dolore magna aliqua.
          </p>
          <p class="paragraph">
            <strong class="bold">Duis</strong>
            <em class="italic">ultricies lacus</em>
            <code class="code">sed</code>
            turpis tincidunt <a class="link" href="#">id</a>. Rhoncus mattis
            rhoncus urna neque viverra justo nec.
          </p>
        </div>
      </div>
      <br />
      <hr class="divider" />
      <br />
      <div class="wrap">
        <button class="button primary">Primary</button>
        <button class="button">Secondary</button>
        <button class="button tertiary">Tertiary</button>
        <label class="checkbox">
          <input type="checkbox" />
          Checkbox
        </label>
        <label class="field">
          Field
          <input type="text" />
        </label>
      </div>
    </div>
  </dialog>
  <form id="builder" class="form stack vertical">
    <Section title="General">
      <Field label="Roundness" orientation="horizontal">
        <RadioCard name="roundness" value="less">
          Less Round
          <!-- <RoundnessArc radius="3px" /> -->
        </RadioCard>
        <RadioCard name="roundness" value="medium">
          Medium (default)
          <!-- <RoundnessArc radius="6px" /> -->
        </RadioCard>
        <RadioCard name="roundness" value="more">
          Rounder
          <!-- <RoundnessArc radius="8px" /> -->
        </RadioCard>
      </Field>
      <Field label="Density" orientation="horizontal">
        <RadioCard name="density" value="less">
          Denser
          <!-- <DensityIcon space="0.5em" /> -->
        </RadioCard>
        <RadioCard name="density" value="medium">
          Medium (default)
          <!-- <DensityIcon space="0.75em" /> -->
        </RadioCard>
        <RadioCard name="density" value="more">
          More Spacious
          <!-- <DensityIcon space="1em" /> -->
        </RadioCard>
      </Field>
      <Field label="Depth" orientation="horizontal">
        <RadioCard name="depth" value="less"> More Shallow </RadioCard>
        <RadioCard name="depth" value="medium"> Medium (default) </RadioCard>
        <RadioCard name="depth" value="more"> Deeper </RadioCard>
      </Field>
      <Field label="Animation Speed" orientation="horizontal">
        <RadioCard name="animationSpeed" value="more"> Faster </RadioCard>
        <RadioCard name="animationSpeed" value="medium">
          Medium (default)
        </RadioCard>
        <RadioCard name="animationSpeed" value="less"> Slower </RadioCard>
      </Field>
    </Section>

    <Section title="Colors">
      <Field label="Brand Color (Hue)">
        <div class="spectrum hue">
          <input
            name="brandColorHue"
            type="range"
            class="slider"
            style="width: 100%"
            min="0"
            max="360"
          />
        </div>
      </Field>
      <Field label="Brand Color (Saturation)">
        <div class="spectrum saturation">
          <input
            name="brandColorSaturation"
            type="range"
            class="slider"
            style="width: 100%"
            min="0"
            max="2"
            step="0.1"
          />
        </div>
      </Field>
      <Field label="Gray Tint" orientation="horizontal">
        <RadioCard name="grays" value="warm">
          Warm
          <GraySwatch color="#848078" />
        </RadioCard>
        <RadioCard name="grays" value="neutral">
          Neutral
          <GraySwatch color="#727272" />
        </RadioCard>
        <RadioCard name="grays" value="default">
          Default (medium-cool)
          <GraySwatch color="#75787c" />
        </RadioCard>
        <RadioCard name="grays" value="cool">
          Cool
          <GraySwatch color="#7b8188" />
        </RadioCard>
        <RadioCard name="grays" value="brand">
          Match Brand Color
          <GraySwatch color="var(--color-brand-5)" />
        </RadioCard>
      </Field>
      <output class="gray-tint-preview">Sample</output>
    </Section>

    <Section title="Fonts">
      <Field label="Body Font">
        <input
          name="bodyFont"
          type="text"
          class="input"
          placeholder='"Avenir Next", Avenir, "Segoe UI Variable Display", "Segoe UI", "URW Gothic", source-sans-pro, "Noto Sans", ui-sans-serif, sans-serif'
        />
      </Field>
      <Field label="Heading Font">
        <input
          name="headingFont"
          type="text"
          class="input"
          placeholder='Seravek, Tahoma, Cantarell, "DejaVu Sans", source-sans-pro, ui-sans-serif, sans-serif'
        />
      </Field>
      <Field label="Monospace Font">
        <input
          name="monoFont"
          type="text"
          class="input"
          placeholder='ui-monospace, "Cascadia Code", menlo, hack, monospace'
        />
      </Field>
      <Field
        label="Font Face Declarations"
        helpText="If you need @font-face declarations, add them here."
      >
        <textarea name="fontFaceDeclarations" rows="4"></textarea>
      </Field>
    </Section>

    <Section title="Download Options">
      <Field label="Name">
        <input
          name="name"
          type="text"
          class="input"
          placeholder="Enter theme name"
        />
      </Field>
      <label class="checkbox">
        <input name="addHash" type="checkbox" />
        Add hash to filename
      </label>

      <button class="button primary">Download</button>
    </Section>
  </form>

  <style>
    .toolbar {
      display: flex;
      align-items: center;
      justify-content: end;
      margin-block-end: var(--space-s);
      gap: var(--space-2xs);
      z-index: 4;
      /* background-color: var(--color-surface-primary);
    border: var(--border-s) solid var(--color-border);
    border-radius: var(--radius-l);
    box-shadow: var(--shadow-m); */
      background-color: var(--glass-bg-color);
      color: var(--glass-fg-color);
      border-bottom: var(--border-s) solid var(--glass-border-color);
      backdrop-filter: var(--glass-filter);
      padding: var(--space-2xs) var(--space-body-x);
      position: sticky;
      top: 0;
      margin-block-start: calc(var(--space-body-y) * -1);
      margin-inline: calc(var(--space-body-x) * -1);
      box-shadow: var(--shadow-s);
    }

    .toolbar > * {
      width: fit-content;
    }

    .side-label {
      margin-inline-end: 0.25em;
      font-size: var(--font-size-s);
      font-weight: var(--font-weight-semibold);
    }

    .brand-color-preview {
      width: 1.5em;
      height: 1.5em;
      border-radius: var(--radius-s);
      border: var(--border-s) solid var(--color-border);
    }

    .gray-tint-preview {
      /* display: inline-flex;
    align-items: center; */
      margin-block: auto;
      margin-inline-end: auto;
      background-color: var(--color-gray-8);
      color: var(--color-gray-3);
      padding: 0.5em;
      border-radius: 0.25em;
    }

    .spectrum {
      padding-block: 0.25em;
    }

    .spectrum.hue {
      --gradient-params: to right in oklch longer hue;
      --spectrum-start: oklch(0.65 0.15 0);
      --spectrum-end: oklch(0.65 0.15 360);
    }

    .spectrum.saturation {
      --gradient-params: to right in oklch;
      --spectrum-start: oklch(0.65 0 200);
      --spectrum-end: oklch(0.65 0.2 200);
    }

    .spectrum input::-webkit-slider-runnable-track {
      block-size: 0.33em;
      background: linear-gradient(
        var(--gradient-params),
        var(--spectrum-start),
        var(--spectrum-end)
      );
    }

    .spectrum input::-moz-range-track {
      block-size: 0.33em;
      background: linear-gradient(
        var(--gradient-params),
        var(--spectrum-start),
        var(--spectrum-end)
      );
    }
  </style>
  <script>
    import { colordx } from "@colordx/core";

    const debounce = <T extends any[]>(
      fn: (...args: T) => void,
      delay: number,
    ) => {
      let timeoutId: number | null = null;
      let hasRun = false;
      return (...args: T) => {
        if (!hasRun) {
          fn(...args);
          hasRun = true;
        }
        if (timeoutId) {
          clearTimeout(timeoutId);
        }
        timeoutId = window.setTimeout(() => {
          hasRun = false;
          timeoutId = null;
        }, delay);
      };
    };

    const values = {
      roundness: {
        less: { s: 2, m: 3, l: 8, xl: 16, "2xl": 44 },
        medium: { s: 3, m: 6, l: 12, xl: 24, "2xl": 64 },
        more: { s: 4, m: 8, l: 16, xl: 32, "2xl": 128 },
        most: { s: 6, m: 12, l: 24, xl: 48, "2xl": 256 },
      },
      density: {},
      depth: {
        less: {
          s: "0 1px 2px -1px",
          m: "0 1px 5px -1px",
          l: "0 2px 9px -1px",
          xl: "0 3px 11px -1px",
        },
        medium: {
          s: "0 1px 3px -1px",
          m: "0 1px 7px -1px",
          l: "0 2px 11px -1px",
          xl: "0 3px 15px -1px",
        },
        more: {
          s: "0 1px 4px -1px",
          m: "0 1px 8px -1px",
          l: "0 2px 12px -1px",
          xl: "0 3px 16px -1px",
        },
      },
      animationSpeed: {
        less: { s: 75, m: 125, l: 150, xl: 250 },
        medium: { s: 100, m: 150, l: 250, xl: 350 },
        more: { s: 150, m: 200, l: 300, xl: 450 },
        most: { s: 200, m: 300, l: 400, xl: 600 },
      },
      grayTints: {
        warm: { chroma: 0.0125, hue: 82 },
        neutral: { chroma: 0, hue: 0 },
        default: { chroma: 0, hue: 0 },
        cool: { chroma: 0.0125, hue: 250 },
        brand: { chroma: 0.015, hue: -1 },
      },
      standardPaletteLightnessStops: [
        0.17, 0.25, 0.33, 0.4, 0.5, 0.62, 0.71, 0.85, 0.95, 0.96,
      ],
      brandColorChromaStops: [
        0.1, 0.15, 0.2, 0.22, 0.23, 0.21, 0.14, 0.08, 0.03, 0.02,
      ],
      semanticColors: {
        "surface-primary": { light: "#fff", dark: "#010203" },
        "surface-secondary": { light: "#f9fafc", dark: "#14161a" },
        "surface-tertiary": { light: "#eceff4", dark: "#212327" },
        "text-primary": { light: "#030305", dark: "#fff" },
        "text-secondary": { light: "#404247", dark: "#ccced0" },
        "text-tertiary": {
          light: "var(--color-brand-3)",
          dark: "var(--color-brand-3)",
        },
        "contrast-background": {
          light: "var(--color-brand-1)",
          dark: "var(--color-brand-1)",
        },
        "contrast-text": { light: "#fff", dark: "#030305" },
        shadow: { light: "#45484c26", dark: "#00000166" },
        border: { light: "#e2e5ea", dark: "#303337" },
      },
    };

    const defaultConfig = {
      roundness: "medium",
      density: "medium",
      depth: "medium",
      animationSpeed: "medium",
      grays: "default",
      brandColorHue: "280",
      brandColorSaturation: "1",
      bodyFont:
        '"Avenir Next", Avenir, "Segoe UI Variable Display", "Segoe UI", "URW Gothic", source-sans-pro, "Noto Sans", ui-sans-serif, sans-serif',
      headingFont:
        'Seravek, Tahoma, Cantarell, "DejaVu Sans", source-sans-pro, ui-sans-serif, sans-serif',
      monoFont: 'ui-monospace, "Cascadia Code", menlo, hack, monospace',
      fontFaceDeclarations: "",
      name: "Untitled Theme",
      addHash: "false",
    };

    const getStoredValue = (fieldName: string) => {
      return (
        localStorage.getItem(`themeBuilder.${fieldName}`) ??
        defaultConfig[fieldName as keyof typeof defaultConfig] ??
        ""
      );
    };

    const updateLivePreview = () => {
      let additionalCss = "";
      let css = ":root, ::backdrop, .light-mode, .dark-mode, .modal, .drawer {";

      // Roundness CSS
      const roundness = getStoredValue(
        "roundness",
      ) as keyof typeof values.roundness;
      const roundnessConfig = values.roundness[roundness];

      css += `
      --radius-s: ${roundnessConfig.s}px;
      --radius-m: ${roundnessConfig.m}px;
      --radius-l: ${roundnessConfig.l}px;
      --radius-xl: ${roundnessConfig.xl}px;
      --radius-2xl: ${roundnessConfig["2xl"]}px;
    `;
      additionalCss += `.button:is(:hover, .hover)::before {
      border-radius: ${roundnessConfig.m - 1}px;
    }`;

      // Density CSS
      //todo

      // Depth CSS
      const depth = getStoredValue("depth") as keyof typeof values.depth;
      const depthConfig = values.depth[depth];
      css += `
      --shadow-s: ${depthConfig.s} var(--color-shadow);
      --shadow-m: ${depthConfig.m} var(--color-shadow);
      --shadow-l: var(--shadow-s), ${depthConfig.l} var(--color-shadow);
      --shadow-xl: var(--shadow-m), ${depthConfig.xl} var(--color-shadow);
    `;

      const animationSpeed = getStoredValue(
        "animationSpeed",
      ) as keyof typeof values.animationSpeed;
      const animationSpeedConfig = values.animationSpeed[animationSpeed];
      css += `
      --duration-s: ${animationSpeedConfig.s}ms;
      --duration-m: ${animationSpeedConfig.m}ms;
      --duration-l: ${animationSpeedConfig.l}ms;
      --duration-xl: ${animationSpeedConfig.xl}ms;
    `;

      // Define gray and brand colors
      const brandColorHue = getStoredValue("brandColorHue");
      const brandColorSaturation = getStoredValue("brandColorSaturation");
      const grayTint = getStoredValue("grays") as keyof typeof values.grayTints;
      const grayTintConfig = values.grayTints[grayTint];

      // Brand colors
      let brandTransparentLight,
        brandExtraTransparentLight,
        brandTransparentDark,
        brandExtraTransparentDark;
      for (let i = 0; i < values.standardPaletteLightnessStops.length; i++) {
        const lightColor = colordx({
          l: values.standardPaletteLightnessStops.at(i)!,
          c: values.brandColorChromaStops.at(i)! * Number(brandColorSaturation),
          h: Number(brandColorHue),
        });
        const darkColor = colordx({
          l:
            (values.standardPaletteLightnessStops.at(0 - i)! +
              values.standardPaletteLightnessStops.at(0 - 1 - i)!) /
            2,
          c:
            (values.brandColorChromaStops.at(0 - i)! *
              Number(brandColorSaturation) +
              values.brandColorChromaStops.at(0 - 1 - i)! *
                Number(brandColorSaturation)) /
            2,
          h: Number(brandColorHue),
        });
        css += `--color-brand-${i + 1}: light-dark(${lightColor.toHex()}, ${darkColor.toHex()});\n`;
        if (i === 5) {
          brandTransparentLight = lightColor.toHex() + "66";
          brandExtraTransparentLight = lightColor.toHex() + "33";
        } else if (i === 4) {
          brandTransparentDark = darkColor.toHex() + "80";
          brandExtraTransparentDark = darkColor.toHex() + "59";
        }
      }
      css += `
      --color-brand-transparent: light-dark(${brandTransparentLight}, ${brandTransparentDark});
      --color-brand-extra-transparent: light-dark(${brandExtraTransparentLight}, ${brandExtraTransparentDark});
    `;

      // Gray colors
      let grayTransparentLight,
        grayExtraTransparentLight,
        grayTransparentDark,
        grayExtraTransparentDark;
      for (let i = 0; i < values.standardPaletteLightnessStops.length; i++) {
        const lightColor = colordx({
          l: values.standardPaletteLightnessStops.at(i)!,
          c: grayTintConfig.chroma,
          h: grayTint === "brand" ? Number(brandColorHue) : grayTintConfig.hue,
        });
        const darkColor = colordx({
          l:
            (values.standardPaletteLightnessStops.at(0 - i)! +
              values.standardPaletteLightnessStops.at(0 - 1 - i)!) /
            2,
          c: grayTintConfig.chroma,
          h: grayTint === "brand" ? Number(brandColorHue) : grayTintConfig.hue,
        });
        css += `--color-gray-${i + 1}: light-dark(${lightColor.toHex()}, ${darkColor.toHex()});\n`;
        if (i === 5) {
          grayTransparentLight = lightColor.toHex() + "66";
          grayExtraTransparentLight = lightColor.toHex() + "33";
        } else if (i === 4) {
          grayTransparentDark = darkColor.toHex() + "80";
          grayExtraTransparentDark = darkColor.toHex() + "59";
        }
      }
      css += `
      --color-gray-transparent: light-dark(${grayTransparentLight}, ${grayTransparentDark});
      --color-gray-extra-transparent: light-dark(${grayExtraTransparentLight}, ${grayExtraTransparentDark});
    `;

      // Other grays
      Object.entries(values.semanticColors).forEach(([name, colorPair]) => {
        let tintedLight = colorPair.light;
        let tintedDark = colorPair.dark;
        if (!tintedLight.startsWith("var(")) {
          const lightOklch = colordx(colorPair.light).toOklch();
          tintedLight = colordx({
            l: lightOklch.l,
            c: grayTint === "neutral" ? 0 : lightOklch.c,
            h:
              grayTint === "brand" ? Number(brandColorHue) : grayTintConfig.hue,
            alpha: lightOklch.alpha,
          }).toHex();
        }
        if (!tintedDark.startsWith("var(")) {
          const darkOklch = colordx(colorPair.dark).toOklch();
          tintedDark = colordx({
            l: darkOklch.l,
            c: grayTint === "neutral" ? 0 : darkOklch.c,
            h:
              grayTint === "brand" ? Number(brandColorHue) : grayTintConfig.hue,
            alpha: darkOklch.alpha,
          }).toHex();
        }

        if (colorPair.light === colorPair.dark) {
          css += `--color-${name}: ${tintedLight};\n`;
        } else {
          css += `--color-${name}: light-dark(${tintedLight}, ${tintedDark});\n`;
        }
      });

      css += "}";
      css += additionalCss;

      let style = document.querySelector<HTMLStyleElement>("#live-preview");
      if (style) {
        style.textContent = css;
      } else {
        style = document.createElement("style");
        style.id = "live-preview";
        style.textContent = css;
        document.head.appendChild(style);
      }
    };

    const setFieldValue = (fieldName: string, value: string) => {
      // First, store the value in localStorage
      localStorage.setItem(`themeBuilder.${fieldName}`, value);

      // Next, update the field in the UI
      const fieldElements = document.querySelectorAll<HTMLElement>(
        `[name="${fieldName}"]`,
      );

      const firstElement = fieldElements[0];
      if (!firstElement) return;
      let inputType = firstElement.tagName.toLowerCase();
      if (inputType === "input") {
        inputType = (firstElement as HTMLInputElement).type || "text";
      }

      switch (inputType) {
        case "text":
        case "range":
        case "textarea":
          fieldElements.forEach((element) => {
            (element as HTMLInputElement | HTMLTextAreaElement).value = value;
          });
          break;
        case "radio":
          fieldElements.forEach((input) => {
            (input as HTMLInputElement).checked =
              (input as HTMLInputElement).value === value;
          });
          break;
        case "checkbox":
          const isChecked = value === "true";
          fieldElements.forEach((input) => {
            (input as HTMLInputElement).checked = isChecked;
          });
          break;
        default:
          console.warn(`Unsupported input type: ${inputType}`);
      }

      updateLivePreview();
    };

    const applyStoredConfig = () => {
      const storedRoundness = getStoredValue("roundness");
      setFieldValue("roundness", storedRoundness);

      const storedDensity = getStoredValue("density");
      setFieldValue("density", storedDensity);

      const storedDepth = getStoredValue("depth");
      setFieldValue("depth", storedDepth);

      const storedAnimationSpeed = getStoredValue("animationSpeed");
      setFieldValue("animationSpeed", storedAnimationSpeed);

      const storedGrays = getStoredValue("grays");
      setFieldValue("grays", storedGrays);

      const storedBrandColorHue = getStoredValue("brandColorHue");
      setFieldValue("brandColorHue", storedBrandColorHue);

      const storedBrandColorSaturation = getStoredValue("brandColorSaturation");
      setFieldValue("brandColorSaturation", storedBrandColorSaturation);

      const storedBodyFont = getStoredValue("bodyFont");
      setFieldValue("bodyFont", storedBodyFont);

      const storedHeadingFont = getStoredValue("headingFont");
      setFieldValue("headingFont", storedHeadingFont);

      const storedMonoFont = getStoredValue("monoFont");
      setFieldValue("monoFont", storedMonoFont);

      const storedFontFaceDeclarations = getStoredValue("fontFaceDeclarations");
      setFieldValue("fontFaceDeclarations", storedFontFaceDeclarations);

      const storedName = getStoredValue("name");
      setFieldValue("name", storedName);

      const storedAddHash = getStoredValue("addHash");
      setFieldValue("addHash", storedAddHash);
    };

    const reset = () => {
      for (const key of Object.keys(localStorage)) {
        if (key.startsWith("themeBuilder.")) {
          localStorage.removeItem(key);
        }
      }
      applyStoredConfig();
    };

    applyStoredConfig();

    const form = document.getElementById("builder")!;
    form
      .querySelectorAll<HTMLInputElement | HTMLTextAreaElement>("[name]")
      .forEach((input) => {
        input.addEventListener("input", () =>
          setFieldValue(
            input.name,
            input.type === "checkbox"
              ? String((input as HTMLInputElement).checked)
              : input.value,
          ),
        );
      });
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      (async () => {
        const name = getStoredValue("name") || "Untitled Theme";
        const addHash = getStoredValue("addHash") === "true";
        const css = (document.getElementById(
          "live-preview",
        ) as HTMLStyleElement)!.textContent;

        let filename = `concord-theme-${name}`;
        if (addHash) {
          const hashBuffer = await crypto.subtle.digest(
            "SHA-1",
            new TextEncoder().encode(css ?? ""),
          );
          const hashArray = Array.from(new Uint8Array(hashBuffer));
          const hashHex = hashArray
            .map((b) => b.toString(16).padStart(2, "0"))
            .join("")
            .slice(0, 8); // Use first 8 characters of the hash
          filename += `-${hashHex}.css`;
        } else {
          filename += ".css";
        }

        const fileContent = `/* Concord Theme - ${name.replaceAll("*", "")} */\n${css}`;
        const blob = new Blob([fileContent], { type: "text/css" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = filename;
        a.click();
        URL.revokeObjectURL(url);
      })();
    });
    document.getElementById("reset")!.addEventListener("click", reset);
    document.getElementById("color-mode")!.addEventListener("change", (e) => {
      const value = (e.target as HTMLSelectElement).value;
      const app = document.querySelector(".app")!;
      app.classList.toggle("light-mode", value === "light");
      app.classList.toggle("dark-mode", value === "dark");
    });
  </script>
</Layout>
