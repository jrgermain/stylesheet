---
import Layout from "../layouts/Layout.astro";
import portraitBgOnly from "../assets/contrast-bg-light.jpg";
import { navCategories } from "../data/nav-links";
import TableOfContents from "../components/TableOfContents.astro";
---

<style define:vars={{ "splash-bg": `url(${portraitBgOnly.src})` }}>
  .splash-container {
    height: 22rem;
    position: relative;
    inset-inline-end: var(--space-body-x);
    margin-block: calc(-1 * var(--space-body-y)) var(--space-xs);
    width: calc(100% + 2 * var(--space-body-x));
    background-color: var(--color-contrast-background);
    background-image: var(--splash-bg);
    background-size: cover;
    background-position: center top;
    display: flex;
    align-items: center;
    justify-content: center;
    transition-property: margin, border-radius, box-shadow;
    transition-duration: var(--duration-l);
    transition-timing-function: var(--ease-out);
  }

  .splash-text {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-black);
    line-height: 1;
    max-width: min(var(--app-max-content-width), 20em);
    padding-inline: var(--space-body-x);
    text-align: center;
    color: var(--color-contrast-text);
    text-wrap: balance;
    margin: var(--space-s);
  }

  @media (width >= 80rem) {
    .splash-container {
      margin: 0;
      margin-block-end: var(--space-body-y);
      inset-inline-end: 0;
      border-radius: var(--radius-l);
      width: 100%;
      box-shadow: var(--shadow-xl);
    }
  }
</style>
<Layout title="Stylesheet">
  <div class="splash-container light-mode">
    <div class="heading level-1 splash-text">
      A lightweight design system for beautiful websites.
    </div>
  </div>
  <div class="alert subtle info">
    <div class="alert-content">
      New here? Check out the <a
        class="link"
        href="/info/getting-started/introduction">Introduction page</a
      > for an overview.
    </div>
  </div>
  <TableOfContents contents={navCategories} />
</Layout>
