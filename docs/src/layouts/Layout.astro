---
import "@jrgermain/stylesheet/stylesheet.css";
import NavLink from "../components/NavLink.astro";
import joey from "../assets/joey.jpg";
import { navCategories } from "../data/nav-links";
import { getNavigationInfo } from "../utils/nav";

interface Props {
  title: string;
}

const { title } = Astro.props;

// Get nav links for the current screen
const nav = getNavigationInfo(Astro.url.pathname);
const shouldShowFooter =
  nav.currentPage != null && (nav.previousPage != null || nav.nextPage != null);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta
      name="description"
      content="Documentation for @jrgermain/stylesheet - a stylesheet for apps I build."
    />
    <meta name="theme-color" content="#fff" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="oklch(8% 2% 263deg)"
    />
    <script>
      import "@jrgermain/stylesheet/enhance";
    </script>
  </head>
  <body class="app">
    <a class="skip-link" href="#main-content">Skip to Main Content</a>
    <header class="app-header">
      <div class="app-header-content">
        <div class="app-header-left">
          <a class="app-header-item" href="/">
            <img class="app-icon" aria-hidden="true" src={joey.src} />
            <span class="app-title-separator"></span>
            <span class="app-title">stylesheet</span>
          </a>
        </div>
        <div class="app-header-center">
          {
            navCategories.map((category) => (
              <NavLink href={`/${category.slug}`} class="app-header-item">
                {category.title}
              </NavLink>
            ))
          }
          <hr class="app-header-divider" />
          <a
            class="app-header-item"
            href="https://github.com/jrgermain/stylesheet"
            title="GitHub"
          >
            <svg aria-hidden="true" viewBox="0 0 98 96" class="github-logo">
              <path
                fill="currentColor"
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.141-22.243-5.378-22.243-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z"
              ></path>
            </svg>
            <span class="visually-hidden">GitHub</span>
          </a>
          <a
            class="app-header-item"
            href="https://www.npmjs.com/package/@jrgermain/stylesheet"
            title="NPM"
          >
            <svg aria-hidden="true" viewBox="0 0 780 250" class="npm-logo">
              <path
                fill="currentColor"
                d="M240,250h100v-50h100V0H240V250z M340,50h50v100h-50V50z M480,0v200h100V50h50v150h50V50h50v150h50V0H480z M0,200h100V50h50v150h50V0H0V200z"
              ></path>
            </svg>
            <span class="visually-hidden">NPM</span>
          </a>
        </div>
        <div class="app-header-right">
          <label class="app-header-item app-sidebar-toggle if-app-has-sidebar">
            <input type="checkbox" title="Toggle navigation" />
            <div></div>
            <div></div>
            <div></div>
          </label>
        </div>
      </div>
    </header>
    <div class="app-body">
      {
        nav.currentCategory != null &&
          nav.currentCategory.sections.length > 0 && (
            <nav class="app-sidebar">
              <div class="app-sidebar-content">
                {nav.currentCategory.sections.map((section) => (
                  <section class="app-sidebar-section">
                    <h1 class="app-sidebar-heading">{section.title}</h1>
                    {section.pages.map((page) => (
                      <NavLink
                        class="app-sidebar-item"
                        href={`/${nav.currentCategory!.slug}/${section.slug}/${page.slug}`}
                      >
                        {page.title}
                      </NavLink>
                    ))}
                  </section>
                ))}
              </div>
            </nav>
          )
      }
      <main id="main-content" class="app-content">
        <slot />
        {
          shouldShowFooter && (
            <footer>
              {nav.previousPage && (
                <a
                  class="previous-link"
                  href={`/${nav.currentCategory!.slug}/${nav.currentSection!.slug}/${nav.previousPage!.slug}`}
                >
                  <svg
                    class="link-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 14"
                    aria-hidden="true"
                  >
                    <line
                      x1="2"
                      y1="2"
                      x2="12"
                      y2="12"
                      stroke="currentColor"
                      stroke-width="1"
                      stroke-linecap="round"
                    />
                    <line
                      x1="12"
                      y1="12"
                      x2="22"
                      y2="2"
                      stroke="currentColor"
                      stroke-width="1"
                      stroke-linecap="round"
                    />
                  </svg>
                  <div class="link-name">Previous</div>
                  <div class="link-title">{nav.previousPage!.title}</div>
                </a>
              )}
              {nav.nextPage && (
                <a
                  class="next-link"
                  href={`/${nav.currentCategory!.slug}/${nav.currentSection!.slug}/${nav.nextPage!.slug}`}
                >
                  <svg
                    class="link-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 14"
                    aria-hidden="true"
                  >
                    <line
                      x1="2"
                      y1="2"
                      x2="12"
                      y2="12"
                      stroke="currentColor"
                      stroke-width="1"
                      stroke-linecap="round"
                    />
                    <line
                      x1="12"
                      y1="12"
                      x2="22"
                      y2="2"
                      stroke="currentColor"
                      stroke-width="1"
                      stroke-linecap="round"
                    />
                  </svg>
                  <div class="link-name">Next</div>
                  <div class="link-title">{nav.nextPage!.title}</div>
                </a>
              )}
            </footer>
          )
        }
      </main>
    </div>
  </body>
</html>
<style>
  .github-logo {
    width: 1.4em;
  }

  .npm-logo {
    width: 2em;
  }

  footer {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    margin-top: var(--space-m);
    width: 100%;
    gap: var(--space-xs) var(--space-s);
  }

  /* On very narrow screens, stack the links vertically */
  @media (width < 25rem) {
    .previous-link,
    .next-link {
      grid-column: 1 / -1 !important;
    }

    .next-link {
      grid-row: 2;
    }
  }

  .previous-link,
  .next-link {
    display: grid;
    grid-template-rows: auto 1fr;
    padding: var(--space-xs);
    border-radius: var(--radius-l);
    text-decoration: none;
    width: 100%;
    column-gap: var(--space-xs);
    border: var(--border-s) dashed var(--color-border);
  }

  :is(.previous-link, .next-link):focus-visible {
    border-color: transparent;
  }

  .previous-link {
    text-align: start;
    grid-template-columns: auto 1fr;
    grid-column: 1;
  }

  .next-link {
    text-align: end;
    grid-template-columns: 1fr auto;
    grid-column: 2;
  }

  .link-name {
    font-size: var(--font-size-s);
    font-weight: var(--font-weight-bold);
    font-family: var(--font-family-heading);
    margin-block-end: 0.05em;
    color: var(--color-text-secondary);
    grid-row: 1;
    transition: color var(--duration-m) var(--ease-default);
  }

  .link-title {
    font-size: var(--font-size-m);
    grid-row: 2;
    transition: color var(--duration-m) var(--ease-default);
    transition-property: color, text-decoration-color;
    color: var(--color-teal-4);
    font-weight: var(--font-weight-semibold);
    text-decoration-line: underline;
    text-decoration-color: var(--color-teal-transparent);
    text-decoration-skip-ink: all;
    text-decoration-thickness: 0.1em;
    text-underline-offset: 0.1em;
  }

  :is(.previous-link, .next-link):hover .link-title {
    text-decoration-color: currentcolor;
  }

  :is(.previous-link, .next-link):active > .link-title {
    color: var(--color-teal-3);
  }

  .previous-link .link-name,
  .previous-link .link-title {
    grid-column: 2;
  }

  .next-link .link-name,
  .next-link .link-title {
    grid-column: 1;
  }

  .link-icon {
    width: 1.5rem;
    margin-block-end: 0.5em;
    margin: auto;
    grid-row: 1 / span 2;
    transition:
      transform var(--duration-m) var(--ease-both),
      color var(--duration-m) var(--ease-default);
    color: var(--color-gray-6);
  }

  .previous-link .link-icon {
    transform: rotate(90deg);
    grid-column: 1;
  }

  .previous-link:hover .link-icon {
    transform: translateX(-0.1em) rotate(90deg);
  }

  .next-link .link-icon {
    transform: rotate(-90deg);
  }

  .next-link:hover .link-icon {
    transform: translateX(0.1em) rotate(-90deg);
  }
</style>
<style is:global>
  [x-cloak] {
    display: none !important;
  }

  .astro-code code {
    background-color: transparent !important;
    padding: 0 !important;
  }
</style>
